# =============================================================================
# Food Ordering Template — Environment Variables
# =============================================================================
# Copy to `.env` (or set as your host's service/environment variables) and fill in.
#
# Per-restaurant config (app name, currency, locales, theme, logo) is RUNTIME,
# set in the admin console at /admin/setup + /admin/settings — NOT via env.
# Only NEXT_PUBLIC_DEFAULT_LOCALE survives as a config env var (see below).

# ── Required secrets (BYOK / infra) ──────────────────────────────────────────
# Database (MySQL — prefer the host's internal/private connection URL in production)
DATABASE_URL="mysql://user:password@host:3306/database"

# Auth.js / NextAuth (v5)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate: openssl rand -base64 32"
# In production, set to your public URL (e.g. https://your-app.example.com)
NEXTAUTH_URL="https://your-app.example.com"
# Set "true" behind a reverse proxy (most PaaS hosts, Vercel, nginx) so Auth.js trusts
# the host header — without it, login fails with `UntrustedHost`. Opt-in by design
# so a bare-host deploy can't be tricked by a spoofed host header.
AUTH_TRUST_HOST="true"

# QR code HMAC secret (signs table QR tokens so they can't be forged)
# Generate with: openssl rand -base64 32
QR_SECRET="generate: openssl rand -base64 32"

# Cron cleanup endpoint secret (sent as Bearer token by the cron service)
# Generate with: openssl rand -base64 32
CRON_SECRET="generate: openssl rand -base64 32"

# Cloudflare R2 (S3-compatible storage for menu images)
# OPTIONAL — empty disables image uploads (UI hidden, endpoint skipped). Menu
# items just have no photos.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Public URL for serving uploaded images (e.g. https://pub-xxxx.r2.dev)
R2_PUBLIC_URL=""

# Cloudflare Turnstile (CAPTCHA / bot protection on admin login)
# OPTIONAL — empty disables it (widget + token check skipped, admin banner shown).
# Keys: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=""
# Site key is client-inlined at build time (Dockerfile build ARG).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# OpenRouter (AI menu import from photos + auto-translation)
# OPTIONAL — empty disables it (UI hidden, endpoints skipped). Add items manually.
OPENROUTER_API_KEY=""

# ── URL-root locale (edge only; optional) ────────────────────────────────────
# routing.ts reads this at the edge (no DB there) to pick which locale `/`
# redirects to. Defaults to "en"; changing it requires a redeploy. All other
# config is set in the admin console.
NEXT_PUBLIC_DEFAULT_LOCALE="en"

# ── Admin seeds (optional; recommended empty in production) ───────────────────
# Each var seeds its own SUPERADMIN when `npx prisma db seed` runs and the var
# has a value (independent — set one, both, or neither):
#   SEED_SUPERADMIN_PASSWORD → seeds `superadminxyz`
#   SEED_DEV_PASSWORD        → seeds `devxyz`
# Seeded accounts are flagged isSeed=true and do NOT close the /admin/setup wizard:
# the wizard stays open until the FIRST NON-SEED admin is created, so the customer
# always registers their own first real admin even if a seed login exists.
# Leave BOTH unset (the recommended production default) → no admin is seeded and the
# wizard owns the first admin cleanly. Set one only for a local-dev shortcut or a
# known-password support login you intend to keep.
# Password policy (enforced by the seed — same rule as the setup wizard & users
# API): 8–16 characters, with at least one uppercase letter, one lowercase
# letter, and one digit. A value that breaks this aborts the seed (nothing is
# written) instead of creating a weak admin.
SEED_SUPERADMIN_PASSWORD=""
SEED_DEV_PASSWORD=""
